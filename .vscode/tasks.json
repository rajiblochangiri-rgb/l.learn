{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lake: build",
      "type": "shell",
      "command": "lake build",
      "group": "build",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Lake: run Mathlib test",
      "type": "shell",
      "command": "lake env lean --run Mathlib_test.lean",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Lean: run current file",
      "type": "shell",
      "command": "lean --run ${fileBasename}",
      "presentation": { "reveal": "always" }
    }
  ]
}
